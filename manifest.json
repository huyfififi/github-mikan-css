{
  "manifest_version": 3,
  "name": "GitHub Background Tint",
  "version": "0.3.13",
  "description": "Tint GitHub surfaces, borders, and primary buttons via Primer CSS variables.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub Background Tint"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://www.github.com/*"],
      "css": ["github-theme.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "css_origin": "user"
    }
  ]
}
