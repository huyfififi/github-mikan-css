{
  "manifest_version": 3,
  "name": "GitHub Mikan CSS",
  "version": "0.1.3",
  "description": "Warm mikan-orange theme for github.com via Primer CSS variables.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub Mikan CSS"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://www.github.com/*"],
      "css": ["github-theme.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "css_origin": "user"
    }
  ]
}
