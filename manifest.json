{
  "manifest_version": 3,
  "name": "GitHub Background Tint",
  "version": "0.3.1",
  "description": "Automatically tint GitHub page backgrounds via Primer CSS variables.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub Background Tint"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*", "https://www.github.com/*"],
      "css": ["github-theme.css"],
      "run_at": "document_start"
    }
  ]
}
